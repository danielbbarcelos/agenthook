# nginx reverse proxy for agenthook (if you already run nginx).
# Exposes ONLY /hook/* and /healthz; /admin, /ui, /jobs return 404 publicly.
# Must run on the same host as agenthook (proxy connects from loopback) so
# uvicorn honors X-Forwarded-For for instance ip-allow / rate-limit.
#
# TLS certs via certbot/letsencrypt. Replace hooks.example.com.

server {
    listen 80;
    server_name hooks.example.com;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name hooks.example.com;

    ssl_certificate     /etc/letsencrypt/live/hooks.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/hooks.example.com/privkey.pem;

    # Public: webhooks + health only.
    location ~ ^/(hook/|healthz$) {
        proxy_pass http://127.0.0.1:8080;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_http_version 1.1;
        proxy_buffering off;          # stream job results (SSE)
        client_max_body_size 25m;     # >= payload_max_kb (512k default); raise for attachments
    }

    # Control-plane surfaces are NOT exposed publicly.
    location /admin { return 404; }
    location /ui    { return 404; }
    location /jobs  { return 404; }
    location /      { return 404; }
}
